# Firebase config — copie para .env.local (dev/demo) ou configure como secrets no GitHub Actions (prod)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# URL da Cloud Function de parse de extratos
NEXT_PUBLIC_FUNCTIONS_URL=

# URL da Cloud Function de envio de email (Resend)
NEXT_PUBLIC_SEND_EMAIL_URL=

# Deixe vazio para dev/demo. Para prod (GitHub Pages), defina como /fincheck-pro
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_GA_ID=
