rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn();
    }

    // Allow any authenticated user to read member docs that contain their own email.
    // Used to detect existing workspace memberships during Google account re-linking.
    match /{path=**}/members/{memberId} {
      allow read: if verified() && resource.data.email == request.auth.token.email;
    }

    function memberPath(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid);
    }

    function isMember(workspaceId) {
      return verified()
        && exists(memberPath(workspaceId))
        && get(memberPath(workspaceId)).data.status == "active";
    }

    function isOwner(workspaceId) {
      return isMember(workspaceId)
        && get(memberPath(workspaceId)).data.role == "owner";
    }

    function inviteIsValid(workspaceId, inviteId) {
      return verified()
        && exists(/databases/$(database)/documents/invites/$(inviteId))
        && get(/databases/$(database)/documents/invites/$(inviteId)).data.workspaceId == workspaceId
        && get(/databases/$(database)/documents/invites/$(inviteId)).data.status == "active"
        && get(/databases/$(database)/documents/invites/$(inviteId)).data.expiresAt > request.time;
    }

    match /users/{userId} {
      allow read, create, update: if verified() && request.auth.uid == userId;
      allow delete: if verified() && request.auth.uid == userId;
    }

    match /cpfIndex/{cpf} {
      allow read: if verified();
      allow create: if verified() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if verified() && resource.data.uid == request.auth.uid;
    }

    // Merchant→category cache, written and read ONLY by the import job via the
    // Admin SDK (which bypasses these rules). Clients have no access.
    match /merchantCategories/{merchant} {
      allow read, write: if false;
    }

    match /consents/{consentId} {
      allow create: if verified() && request.resource.data.uid == request.auth.uid;
      allow read: if verified() && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if resource.data.status == "active"
        && resource.data.expiresAt > request.time;
      allow create: if verified()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "active"
        && isOwner(request.resource.data.workspaceId);
      allow update: if verified() && (
        isOwner(resource.data.workspaceId)
        || (
          resource.data.status == "active"
          && resource.data.expiresAt > request.time
          && request.resource.data.status == "accepted"
          && request.resource.data.acceptedBy == request.auth.uid
        )
      );
      allow delete: if verified()
        && isOwner(resource.data.workspaceId);
    }

    match /workspaces/{workspaceId} {
      allow read: if isMember(workspaceId);
      allow create: if verified()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isMember(workspaceId);
      allow delete: if isOwner(workspaceId)
        && resource.data.confirmDelete == true;

      match /members/{memberId} {
        allow read: if (verified() && resource.data.uid == request.auth.uid)
          || isMember(workspaceId);
        allow create: if verified() && (
          (
            request.auth.uid == memberId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.role == "owner"
            && request.resource.data.status == "active"
            && request.resource.data.createdBy == request.auth.uid
          )
          ||
          (
            request.auth.uid == memberId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.role == "editor"
            && request.resource.data.status == "active"
            && request.resource.data.inviteId is string
            && inviteIsValid(workspaceId, request.resource.data.inviteId)
          )
          ||
          (
            // Account re-linking: Google login with same email as existing member.
            // Allowed when the workspace's memberEmails array includes the requester's email.
            request.auth.uid == memberId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.status == "active"
            && request.resource.data.email == request.auth.token.email
            && request.auth.token.email != null
            && request.auth.token.email in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberEmails
          )
        );
        allow update: if isOwner(workspaceId)
          || (verified() && request.auth.uid == memberId && request.resource.data.status == "left");
        allow delete: if isOwner(workspaceId);
      }

      match /categories/{categoryId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isOwner(workspaceId);
      }

      match /transactions/{transactionId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId);
      }

      match /summaries/{summaryId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isOwner(workspaceId);
      }

      match /plannedItems/{plannedItemId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId);
      }

      match /recurringItems/{recurringItemId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId);
      }

      match /goals/{goalId} {
        allow read, create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId);
      }

      match /openFinanceWaitlist/{waitlistId} {
        allow read: if isOwner(workspaceId);
        allow create: if isMember(workspaceId)
          && waitlistId == request.auth.uid
          && request.resource.data.uid == request.auth.uid;
        allow update: if isMember(workspaceId)
          && waitlistId == request.auth.uid
          && resource.data.uid == request.auth.uid;
        allow delete: if isOwner(workspaceId);
      }

      // Background import jobs — created by the client before uploading to Storage.
      // Only the triggering function (Admin SDK, bypasses rules) writes status/results.
      match /importJobs/{jobId} {
        allow read: if isMember(workspaceId);
        allow create: if isMember(workspaceId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "processing";
        allow update, delete: if false;
      }

      // Credit cards and faturas — written ONLY by the fatura pipeline
      // (Admin SDK, bypasses rules). Members read; clients never write.
      match /cards/{cardId} {
        allow read: if isMember(workspaceId);
        allow write: if false;
      }
      match /faturas/{faturaId} {
        allow read: if isMember(workspaceId);
        allow write: if false;
      }
      // Card diagnosis cache — written ONLY by the generateCardDiagnosis
      // callable (Admin SDK). Members read; clients never write.
      match /cardDiagnoses/{diagId} {
        allow read: if isMember(workspaceId);
        allow write: if false;
      }
    }
  }
}
