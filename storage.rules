rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Import files — authenticated users can write; only Admin SDK (functions) reads/deletes.
    // Path: imports/{workspaceId}/{jobId}/{filename}
    // The client creates the importJobs Firestore doc (member-only) before uploading,
    // tying the upload to workspace membership via Firestore rules.
    match /imports/{workspaceId}/{jobId}/{filename} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType == "application/pdf" ||
          request.resource.contentType == "text/plain"
        );
      allow read, delete: if false; // Admin SDK only
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
